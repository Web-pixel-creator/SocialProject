NODE_ENV=development
PORT=4000
DATABASE_URL=postgres://postgres:postgres@localhost:5432/finishit
REDIS_URL=redis://localhost:6379
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=finishit
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
FRONTEND_URL=http://localhost:3000
JWT_SECRET=dev-secret
JWT_EXPIRES_IN=7d
TERMS_VERSION=v1
PRIVACY_VERSION=v1
LOG_LEVEL=info
# For NODE_ENV=test, default log level is silent unless TEST_LOGS_ENABLED=true
# TEST_LOGS_ENABLED=true
JOBS_ENABLED=true
AUTOPSY_LONG_CONTEXT_ENABLED=false
CSRF_TOKEN=dev-csrf
EMBEDDING_PROVIDER=hash
EMBEDDING_API_URL=https://api.jina.ai/v1/embeddings
EMBEDDING_API_KEY=
EMBEDDING_MODEL=jina-clip-v2
EMBEDDING_DIMENSIONS=1024
EMBEDDING_TIMEOUT_MS=8000
SANDBOX_EXECUTION_ENABLED=false
SANDBOX_EXECUTION_EGRESS_ENFORCE=false
SANDBOX_EXECUTION_EGRESS_PROFILES=
SANDBOX_EXECUTION_EGRESS_PROVIDER_ALLOWLISTS=
SANDBOX_EXECUTION_LIMITS_ENFORCE=false
SANDBOX_EXECUTION_OPERATION_LIMIT_PROFILES=
SANDBOX_EXECUTION_LIMIT_PROFILES=
ADMIN_API_TOKEN=change-me
ENABLE_DEMO_FLOW=false
DEEPGRAM_API_KEY=
DEEPGRAM_VOICE_RENDER_BASE_URL=https://api.deepgram.com/v1
DEEPGRAM_VOICE_RENDER_MODEL=aura-2-thalia-en
DEEPGRAM_VOICE_RENDER_LANGUAGE=en
DEEPGRAM_VOICE_RENDER_TIMEOUT_MS=15000
LIVE_SESSION_RECAP_VOICE_RENDER_ENABLED=false
PERPLEXITY_API_KEY=
PERPLEXITY_BASE_URL=https://api.perplexity.ai
PERPLEXITY_SONAR_MODEL=sonar-pro
PERPLEXITY_TIMEOUT_MS=20000
GEMINI_API_KEY=
GEMINI_GROUNDED_RESEARCH_BASE_URL=https://generativelanguage.googleapis.com/v1beta
GEMINI_GROUNDED_RESEARCH_MODEL=gemini-2.5-flash
GEMINI_GROUNDED_RESEARCH_TIMEOUT_MS=20000
FAL_API_KEY=
FAL_IMAGE_EDIT_BASE_URL=https://queue.fal.run
FAL_IMAGE_EDIT_MODEL=fal-ai/nano-banana-2/edit
FAL_IMAGE_EDIT_TIMEOUT_MS=15000
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=https://api.anthropic.com/v1
ANTHROPIC_LONG_CONTEXT_MODEL=claude-sonnet-4-20250514
ANTHROPIC_LONG_CONTEXT_TIMEOUT_MS=30000
ANTHROPIC_VERSION=2023-06-01
ANTHROPIC_SERVICE_TIER=auto
ANTHROPIC_LONG_CONTEXT_INPUT_COST_PER_MTOKENS=3
ANTHROPIC_LONG_CONTEXT_OUTPUT_COST_PER_MTOKENS=15
ANTHROPIC_LONG_CONTEXT_CACHE_WRITE_5M_COST_PER_MTOKENS=3.75
ANTHROPIC_LONG_CONTEXT_CACHE_WRITE_1H_COST_PER_MTOKENS=6
ANTHROPIC_LONG_CONTEXT_CACHE_READ_COST_PER_MTOKENS=0.3
AI_PROVIDER_LANE_CONFIGS=
AI_PROVIDER_LANE_DISABLED_PROVIDERS=
HEAVY_RATE_LIMIT_WINDOW_MS=900000
HEAVY_RATE_LIMIT_MAX=30
# Search relevance tuning (Balanced default)
SEARCH_RELEVANCE_WEIGHT_KEYWORD=0.6
SEARCH_RELEVANCE_WEIGHT_GLOWUP=0.3
SEARCH_RELEVANCE_WEIGHT_RECENCY=0.1
SEARCH_RELEVANCE_WEIGHT_STUDIO_KEYWORD=0.7
SEARCH_RELEVANCE_WEIGHT_STUDIO_IMPACT=0.3
# Novelty profile (more recent)
# SEARCH_RELEVANCE_WEIGHT_KEYWORD=0.50
# SEARCH_RELEVANCE_WEIGHT_GLOWUP=0.20
# SEARCH_RELEVANCE_WEIGHT_RECENCY=0.30
# SEARCH_RELEVANCE_WEIGHT_STUDIO_KEYWORD=0.65
# SEARCH_RELEVANCE_WEIGHT_STUDIO_IMPACT=0.35
# Quality profile (more glowup/impact)
# SEARCH_RELEVANCE_WEIGHT_KEYWORD=0.45
# SEARCH_RELEVANCE_WEIGHT_GLOWUP=0.45
# SEARCH_RELEVANCE_WEIGHT_RECENCY=0.10
# SEARCH_RELEVANCE_WEIGHT_STUDIO_KEYWORD=0.60
# SEARCH_RELEVANCE_WEIGHT_STUDIO_IMPACT=0.40
